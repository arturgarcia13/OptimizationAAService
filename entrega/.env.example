# ===================================================================
# .env.example — Variáveis de ambiente da aplicação
#
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env
# ===================================================================

# ------------------------------------------------------------------
# OBRIGATÓRIO: Chave de API para autenticação da rota POST /otimizar
# Gere uma chave forte, por exemplo:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# ------------------------------------------------------------------
API_KEY=SUBSTITUA_POR_UMA_CHAVE_FORTE

# ------------------------------------------------------------------
# OPCIONAL: Configurações do solver
# ------------------------------------------------------------------
# Tempo padrão do solver em segundos (padrão: 60)
SOLVER_DEFAULT_TIME_LIMIT=60

# Limite máximo aceito de time_limit enviado pelo cliente (padrão: 120)
SOLVER_MAX_TIME_LIMIT=120

# ------------------------------------------------------------------
# OPCIONAL: Configurações da aplicação
# ------------------------------------------------------------------
# Nome exibido no Swagger UI
APP_NAME=Optimization-as-a-Service — Corte Unidimensional

# Versão da API
APP_VERSION=1.0.0

# Se True, expõe tracebacks completos nas respostas de erro (SOMENTE DESENVOLVIMENTO)
DEBUG=false
