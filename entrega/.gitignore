# ===================================================================
# .gitignore — Filtros de arquivos ignorados no Git
# ===================================================================

# Segredos — NUNCA versionar
.env
*.env

# Ambiente virtual Python
.venv/
venv/
env/
ENV/
__pyenv_version__

# Cache Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# Pytest e cobertura
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.coveragerc

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# Sistema operacional
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# Arquivos temporários
*.tmp
*.bak
